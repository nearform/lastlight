{
  "name": "lastlight",
  "version": "0.20.0",
  "description": "Last Light CLI — a lean global client + host-local `server` lifecycle for the Last Light GitHub maintenance agent, plus the Claude Code plugin.",
  "type": "module",
  "bin": {
    "lastlight": "dist/cli.js"
  },
  "files": [
    "dist",
    "plugins",
    ".claude-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nearform/lastlight.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "github",
    "agent",
    "claude",
    "anthropic",
    "maintenance",
    "cli"
  ],
  "author": "Clifton Cunningham",
  "license": "MIT",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "prepare": "node scripts/copy-plugin.mjs",
    "prebuild": "node scripts/copy-plugin.mjs",
    "prepack": "node scripts/copy-plugin.mjs",
    "build": "tsc && node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "lastlight-shared": "workspace:*",
    "lastlight-workflow-engine": "workspace:*",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
