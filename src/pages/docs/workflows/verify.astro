			<span class="label">&larr; Prev</span>
			<span class="title">Security feedback</span>
		</a>
		<a href="/docs/workflows/qa-test" class="next">
			<span class="label">Next &rarr;</span>
			<span class="title">QA test</span>
		</a>
	</div>
</DocsLayout>

<style is:global>
	.workflow-diagram {
		margin: 1.5rem 0;
		padding: 1.25rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 10px;
		overflow-x: auto;
	}

	.workflow-diagram svg {
		width: 100%;
