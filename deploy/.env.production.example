# ── Last Light — Production Environment ──────────────────────────
# Copy this file to instance/secrets/.env and fill in your values, where
# instance/ is your private deployment overlay (a separate repo cloned next to
# docker-compose.yml). The whole instance/ folder is mounted read-only into the
# container at /app/instance; the entrypoint reads secrets from
# /app/instance/secrets, and both the agent and caddy services read this file
# via env_file. No repo-root .env is needed.
#
# Overlay config + assets (config.yaml + agent-context/ + workflows/ + skills/)
# are read at startup — edit and `lastlight server restart agent` to apply, no
# rebuild. (Removing a var here needs a recreate: `lastlight server start agent`.)
LASTLIGHT_OVERLAY_DIR=/app/instance

# =================================================================
# GITHUB APP (required)
# =================================================================
# Create a GitHub App: https://docs.github.com/en/apps/creating-github-apps
# Permissions: Issues (R/W), Pull Requests (R/W), Contents (R/W), Metadata (R).
# Subscribe to issue, issue_comment, pull_request, and pull_request_review events.
# Drop the App private key at instance/secrets/app.pem (the entrypoint symlinks
# it to /app/app.pem; GITHUB_APP_PRIVATE_KEY_PATH is resolved relative to /app).

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./app.pem
GITHUB_APP_INSTALLATION_ID=

# =================================================================
# WEBHOOK (required)
# =================================================================
# Must match the webhook secret configured in your GitHub App settings.

WEBHOOK_SECRET=change-me-to-a-random-string

# =================================================================
# MODEL + LLM PROVIDER (required — pick one provider key)
# =================================================================
# Default model for sandbox + chat. Any provider/model agentic-pi supports:
# anthropic/…, openai/…, or openrouter/<vendor>/<model>.
LASTLIGHT_MODEL=anthropic/claude-sonnet-4-6

# Set whichever key matches LASTLIGHT_MODEL (set more than one if per-task
# overrides in config.yaml route phases to different providers).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-proj-...
# OPENROUTER_API_KEY=sk-or-...

# =================================================================
# DOMAIN (for Caddy TLS)
# =================================================================
# Public hostname for automatic Let's Encrypt TLS. Leave "localhost" for local
# dev (HTTP only). The webhook URL is https://<DOMAIN>/webhook.

DOMAIN=localhost

# =================================================================
# ADMIN DASHBOARD
# =================================================================
# ADMIN_SECRET signs session tokens (required for login). ADMIN_PASSWORD enables
# password login; auth is also satisfied by a configured OAuth provider below.

ADMIN_SECRET=change-me-to-a-random-string
# ADMIN_PASSWORD=

# =================================================================
# OPTIONAL: SLACK
# =================================================================
# Enables the messaging connector + chat skill (and the chat server).
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_DELIVERY_CHANNEL=          # channel id for cron reports
# SLACK_ALLOWED_USERS=             # comma-separated user ids
#
# "Login with Slack" on the dashboard (OIDC):
# SLACK_OAUTH_CLIENT_ID=
# SLACK_OAUTH_CLIENT_SECRET=
# SLACK_OAUTH_REDIRECT_URI=https://<DOMAIN>/admin/api/auth/slack/callback
# SLACK_ALLOWED_WORKSPACE=         # restrict login to one team_id / domain

# =================================================================
# OPTIONAL: WEB SEARCH (explore workflow only)
# =================================================================
# Set any one to enable agentic-pi's web_search / web_fetch tools for phases
# that opt in (Tavily > Exa > Brave). Other workflows ignore these keys.
# TAVILY_API_KEY=tvly-...
# EXA_API_KEY=...
# BRAVE_SEARCH_API_KEY=BSA...

# =================================================================
# OPTIONAL: RUNTIME
# =================================================================
# PORT=8644                        # webhook listener / admin port
# STATE_DIR=./data                 # persistent state (mounted as a volume)
