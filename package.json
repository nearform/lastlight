{
  "name": "lastlight",
  "version": "0.1.15",
  "description": "GitHub repository maintenance agent — Agent SDK harness",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lastlight": "dist/cli.js"
  },
  "files": [
    "dist",
    "workflows",
    "skills",
    "agent-context",
    "deploy",
    "sandbox.Dockerfile",
    "docker-compose.yml"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cliftonc/lastlight.git"
  },
  "keywords": [
    "github",
    "agent",
    "claude",
    "anthropic",
    "maintenance",
    "workflow"
  ],
  "author": "Clifton Cunningham",
  "license": "MIT",
  "workspaces": [
    "dashboard"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "tsc",
    "build:dashboard": "npm run build -w dashboard",
    "build:all": "tsc && npm run build -w dashboard",
    "start": "node dist/index.js",
    "dev": "concurrently -n server,dash -c blue,magenta \"bash scripts/dev-local.sh\" \"npm run dev -w dashboard\"",
    "dev:server": "bash scripts/dev-local.sh",
    "dev:dashboard": "npm run dev -w dashboard",
    "cli": "tsx src/cli.ts",
    "build:issue": "tsx src/cli.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@earendil-works/pi-ai": "^0.75.4",
    "@hono/node-server": "^1.19.13",
    "@sinclair/typebox": "^0.34.49",
    "@slack/bolt": "^4.6.0",
    "agentic-pi": "^0.2.2",
    "arctic": "^3.7.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.6.2",
    "croner": "^9.0.0",
    "hono": "^4.12.14",
    "octokit": "^5.0.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
