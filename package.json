{
  "name": "agentic-pi",
  "version": "0.2.3",
  "description": "A drop-in coding-agent harness built on earendil-works/pi, designed to replace opencode in workflow-driven systems like lastlight.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cliftonc/agentic-pi.git"
  },
  "homepage": "https://github.com/cliftonc/agentic-pi#readme",
  "bugs": {
    "url": "https://github.com/cliftonc/agentic-pi/issues"
  },
  "keywords": [
    "agent",
    "ai",
    "coding-agent",
    "pi",
    "earendil-works",
    "opencode",
    "lastlight",
    "llm",
    "workflow"
  ],
  "type": "module",
  "bin": {
    "agentic-pi": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "node scripts/run-tests.mjs",
    "test:unit": "node scripts/run-tests.mjs --unit",
    "test:integration": "node scripts/run-tests.mjs --integration",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@earendil-works/gondolin": "^0.12.0",
    "@earendil-works/pi-ai": "^0.75.4",
    "@earendil-works/pi-coding-agent": "^0.75.4",
    "@octokit/auth-app": "^7.1.4",
    "@octokit/rest": "^21.0.2",
    "@sinclair/typebox": "^0.34.0",
    "@types/jsonwebtoken": "^9.0.10",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
