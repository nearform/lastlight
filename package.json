{
  "name": "lastlight",
  "version": "0.16.0",
  "description": "GitHub repository maintenance agent — Agent SDK harness",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./evals": {
      "types": "./dist/evals-api.d.ts",
      "import": "./dist/evals-api.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "bin": {
    "lastlight": "dist/cli/cli.js"
  },
  "files": [
    "dist",
    "config",
    "workflows",
    "skills",
    "agent-context",
    "deploy",
    "sandbox.Dockerfile",
    "docker-compose.yml",
    ".claude-plugin",
    "plugins"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nearform/lastlight.git"
  },
  "keywords": [
    "github",
    "agent",
    "claude",
    "anthropic",
    "maintenance",
    "workflow"
  ],
  "author": "Clifton Cunningham",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "build": "tsc && node -e \"require('fs').chmodSync('dist/cli/cli.js', 0o755)\"",
    "build:dashboard": "pnpm --filter @lastlight/dashboard build",
    "build:all": "pnpm run build && pnpm --filter @lastlight/dashboard build",
    "start": "node dist/index.js",
    "dev": "concurrently -n server,dash -c blue,magenta \"bash scripts/dev-local.sh\" \"pnpm --filter @lastlight/dashboard dev\"",
    "dev:server": "bash scripts/dev-local.sh",
    "dev:dashboard": "pnpm --filter @lastlight/dashboard dev",
    "cli": "tsx src/cli.ts",
    "build:issue": "tsx src/cli.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@earendil-works/pi-ai": "^0.79.8",
    "@hono/node-server": "^1.19.13",
    "@octokit/auth-app": "^8.2.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sinclair/typebox": "^0.34.49",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.16.0",
    "agentic-pi": "^0.2.16",
    "arctic": "^3.7.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "croner": "^9.0.0",
    "hono": "^4.12.14",
    "octokit": "^5.0.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.10.5",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
