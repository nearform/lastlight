{
  "name": "lastlight-evals",
  "version": "0.1.1",
  "description": "Eval harness for Last Light workflows — drives the real production workflows against a mocked GitHub and grades deterministically (SWE-bench compatible).",
  "type": "module",
  "bin": {
    "lastlight-evals": "dist/run.js"
  },
  "files": [
    "dist",
    "datasets",
    "models.json"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/run.js', 0o755)\"",
    "eval": "tsx src/run.ts run",
    "eval:compare": "tsx src/run.ts run --compare",
    "init": "tsx src/run.ts init",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cliftonc/lastlight-evals.git"
  },
  "keywords": [
    "lastlight",
    "evals",
    "swe-bench",
    "agent",
    "workflow"
  ],
  "author": "Clifton Cunningham",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "chalk": "^5.6.2",
    "lastlight": "^0.5.0"
  },
  "peerDependencies": {
    "agentic-pi": "^0.2.11"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "agentic-pi": "^0.2.11",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
